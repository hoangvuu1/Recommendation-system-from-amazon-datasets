# Environment variables for Recommendation System
# Copy this to .env and customize as needed

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
RELOAD=True

# CORS Configuration
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# Content-Based Engine
CONTENT_BASED_ENABLED=True
ATTENTION_MODEL_ENABLED=False

# Feature Flags
LOAD_METADATA=True
LOAD_RECOMMENDATIONS=True
LOAD_POPULAR_ITEMS=True
